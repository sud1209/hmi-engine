# ── LLM API Keys ──────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_API_KEY=...

# ── Database ───────────────────────────────────────────────────────────────
# Default: postgresql+asyncpg://hmi:hmi@postgres:5432/hmi (Docker Compose)
# Override for external managed DB:
DATABASE_URL=postgresql+asyncpg://hmi:hmi@postgres:5432/hmi

# ── Auth ───────────────────────────────────────────────────────────────────
# HMAC secret for JWT signing — change before any public deployment
SECRET_KEY=change-me-before-going-to-production-use-32-random-chars

# SHA-256 hex of the ingest API key (used by POST /ingest/kpis)
# Generate: echo -n "your-api-key" | sha256sum
API_KEY_HASH=

# ── Live data feeds ────────────────────────────────────────────────────────
# NewsAPI key for news feed (falls back to RSS if absent)
NEWS_API_KEY=

# File-based KPI import path (alternative to HTTP push)
# KPI_IMPORT_PATH=/data/kpi_import/latest.json
KPI_IMPORT_PATH=

# ── ChromaDB (episodic memory) ─────────────────────────────────────────────
# Named volume path inside agent-runner container
CHROMA_PATH=/app/data/chroma

# ── Network / HTTPS ────────────────────────────────────────────────────────
# Public domain for Caddy HTTPS — leave as "localhost" for local dev (HTTP only)
DOMAIN=localhost

# Comma-separated origins allowed by CORS
ALLOWED_ORIGINS=http://localhost:3000

# ── Agent runner ───────────────────────────────────────────────────────────
MCP_SERVER_URL=http://mcp-server:8001/sse

# ── Observability ──────────────────────────────────────────────────────────
# "json" (prod) | "console" (dev)
LOG_FORMAT=json

# Sentry DSN — Sentry is disabled if absent
SENTRY_DSN=

# ── CI/CD ──────────────────────────────────────────────────────────────────
# Set in GitHub Actions Secrets / environment:
# DEPLOY_HOST     — SSH host of production server
# DEPLOY_USER     — SSH user (must have docker access)
# DEPLOY_SSH_KEY  — Private key for SSH

# ── Agent settings ─────────────────────────────────────────────────────────
BROWSER_HEADLESS=true
RATE_LIMIT_SECONDS=2.0
SANDBOX_TIMEOUT_SECONDS=30
